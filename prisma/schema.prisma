// AI Development Guideline 참조: 데이터 무결성을 위한 스키마 설계
// 데이터베이스는 PostgreSQL을 사용합니다.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  CREATOR
  ADMIN
}

enum ThemeStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum BuildStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
}

enum InquiryStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model User {
  id                String    @id @default(uuid())
  kakaoId           String    @unique
  email             String?   @unique
  name              String
  nickname          String?   @unique
  avatarUrl         String?
  image             String?
  role              Role      @default(USER)
  isSuspended       Boolean   @default(false)
  credit            Int       @default(0)
  referralCode      String?   @unique
  referralRewarded  Boolean   @default(false)  // 추천 적립을 이미 받았는지 (평생 1회)
  deletedAt         DateTime?                   // soft delete
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  themes         Theme[]        @relation("UserThemes")
  purchases      Purchase[]     @relation("UserPurchases")
  inquiries      Inquiry[]      @relation("UserInquiries")
  inquiryReplies InquiryReply[] @relation("UserInquiryReplies")
  reports        Report[]       @relation("UserReports")
  pointHistories PointHistory[] @relation("UserPointHistories")
}

enum PointType {
  REFERRAL_REWARD
  PURCHASE_USE
  ADMIN_GRANT
  REFUND
}

model PointHistory {
  id        String    @id @default(uuid())
  userId    String
  amount    Int
  type      PointType
  memo      String?
  createdAt DateTime  @default(now())

  user User @relation("UserPointHistories", fields: [userId], references: [id])
}

model Theme {
  id           String      @id @default(uuid())
  creatorId    String
  title        String
  description  String?
  price        Int         @default(0)
  status       ThemeStatus @default(DRAFT)
  thumbnailUrl String?
  adminNote    String?
  images       String[]    @default([])
  tags         String[]    @default([])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  creator   User           @relation("UserThemes", fields: [creatorId], references: [id])
  versions  ThemeVersion[]
  purchases Purchase[]
  reports   Report[]       @relation("ThemeReports")
}

model ThemeVersion {
  id            String      @id @default(uuid())
  themeId       String
  version       String
  configJson    Json
  kthemeFileUrl String?
  apkFileUrl    String?
  buildStatus   BuildStatus @default(PENDING)
  createdAt     DateTime    @default(now())

  theme Theme @relation(fields: [themeId], references: [id], onDelete: Cascade)
}

model Purchase {
  id              String         @id @default(uuid())
  buyerId         String
  themeId         String
  amount          Int
  pgTransactionId String?        @unique
  status          PurchaseStatus @default(PENDING)
  createdAt       DateTime       @default(now())

  buyer User  @relation("UserPurchases", fields: [buyerId], references: [id])
  theme Theme @relation(fields: [themeId], references: [id])
}

model Inquiry {
  id        String        @id @default(uuid())
  userId    String
  category  String        @default("기타")
  title     String
  content   String
  status    InquiryStatus @default(OPEN)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user    User           @relation("UserInquiries", fields: [userId], references: [id])
  replies InquiryReply[]
}

model InquiryReply {
  id        String   @id @default(uuid())
  inquiryId String
  authorId  String
  content   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  author  User    @relation("UserInquiryReplies", fields: [authorId], references: [id])
}

model Report {
  id         String       @id @default(uuid())
  reporterId String
  themeId    String
  reason     String
  detail     String?
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())

  reporter User  @relation("UserReports", fields: [reporterId], references: [id])
  theme    Theme @relation("ThemeReports", fields: [themeId], references: [id])
}
