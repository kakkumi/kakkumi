# ───── Supabase DB ─────
# Supabase 프로젝트 > Settings > Database > Connection String (Transaction mode) 에서 복사
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# Supabase 프로젝트 > Settings > Database > Connection String (Direct connection) 에서 복사
# prisma migrate 실행 시 필요
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ───── 카카오 OAuth ─────
# https://developers.kakao.com > 내 애플리케이션 > 앱 키 > REST API 키
KAKAO_CLIENT_ID=

# https://developers.kakao.com > 내 애플리케이션 > 카카오 로그인 > 보안 > Client Secret
KAKAO_CLIENT_SECRET=

# 카카오 앱 > 카카오 로그인 > Redirect URI 에 등록한 주소와 반드시 동일해야 함
# 로컬 개발: http://localhost:3000/api/auth/kakao/callback
# 운영: https://[도메인]/api/auth/kakao/callback
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/kakao/callback

# 세션 서명에 사용하는 비밀키. 64자 이상의 랜덤 문자열 권장
# ───── 토스페이먼츠 ─────
# https://developers.tosspayments.com > 개발자센터 > API 키
# 테스트 키: test_sk_ / test_ck_ 로 시작 (사업자등록 없이 바로 사용)
# 운영 키:  live_sk_ / live_ck_ 로 시작 (사업자등록 후 사용)
TOSSPAYMENTS_SECRET_KEY=
NEXT_PUBLIC_TOSSPAYMENTS_CLIENT_KEY=

