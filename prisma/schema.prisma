generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CreatorApplication {
  id           String            @id @default(uuid())
  userId       String
  reason       String
  portfolio    String?
  status       ApplicationStatus @default(PENDING)
  adminNote    String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  experience   Boolean           @default(false)
  tools        String[]          @default([])
  sampleImages String[]          @default([])
  user         User              @relation("UserApplications", fields: [userId], references: [id])
}

model User {
  id                    String                 @id @default(uuid())
  email                 String?                @unique
  name                  String
  role                  Role                   @default(USER)
  createdAt             DateTime               @default(now())
  image                 String?
  kakaoId               String                 @unique
  updatedAt             DateTime               @updatedAt
  nickname              String?                @unique
  avatarUrl             String?
  credit                Int                    @default(0)
  deletedAt             DateTime?
  isSuspended           Boolean                @default(false)
  referralCode          String?                @unique
  referralRewarded      Boolean                @default(false)
  notifSettings         Json?
  bankName              String?
  accountNumber         String?
  accountHolder         String?
  applications          CreatorApplication[]   @relation("UserApplications")
  followings            Follow[]               @relation("UserFollowings")
  followers             Follow[]               @relation("UserFollowers")
  galleryComments       GalleryComment[]
  galleryCommentReports GalleryCommentReport[]
  galleryLikes          GalleryLike[]
  galleryPosts          GalleryPost[]
  galleryReactions      GalleryReaction[]
  inquiries             Inquiry[]              @relation("UserInquiries")
  inquiryReplies        InquiryReply[]         @relation("UserInquiryReplies")
  mailboxes             Mailbox[]
  myThemes              MyTheme[]
  myThemeFolders        MyThemeFolder[]
  notifications         Notification[]         @relation("UserNotifications")
  pointHistories        PointHistory[]         @relation("UserPointHistories")
  purchases             Purchase[]             @relation("UserPurchases")
  reports               Report[]               @relation("UserReports")
  reviews               Review[]
  subscription          Subscription?
  subscriptionPayments  SubscriptionPayment[]
  themes                Theme[]                @relation("UserThemes")
  likes                 ThemeLike[]
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowings", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  linkUrl   String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
}

model PointHistory {
  id        String    @id @default(uuid())
  userId    String
  amount    Int
  type      PointType
  memo      String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation("UserPointHistories", fields: [userId], references: [id])
}

model Theme {
  id                      String         @id @default(uuid())
  creatorId               String
  title                   String
  description             String?
  price                   Int            @default(0)
  status                  ThemeStatus    @default(DRAFT)
  thumbnailUrl            String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  adminNote               String?
  images                  String[]       @default([])
  tags                    String[]       @default([])
  isPublic                Boolean        @default(true)
  isSelling               Boolean        @default(true)
  contentBlocks           String?
  pendingTitle            String?
  pendingDescription      String?
  pendingPrice            Int?
  pendingTags             String[]
  pendingThumbnailUrl     String?
  pendingImages           String[]
  pendingContentBlocks    String?
  pendingReviewVisibility String?
  discountPrice           Int?
  purchases               Purchase[]
  reports                 Report[]       @relation("ThemeReports")
  reviews                 Review[]
  creator                 User           @relation("UserThemes", fields: [creatorId], references: [id])
  likes                   ThemeLike[]
  options                 ThemeOption[]
  versions                ThemeVersion[]
}

model ThemeVersion {
  id            String      @id @default(uuid())
  themeId       String
  version       String
  configJson    Json
  kthemeFileUrl String?
  apkFileUrl    String?
  buildStatus   BuildStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  purchases     Purchase[]
  theme         Theme       @relation(fields: [themeId], references: [id], onDelete: Cascade)
}

model ThemeOption {
  id                String            @id @default(uuid())
  themeId           String
  os                String
  name              String
  status            ThemeOptionStatus @default(PENDING_NEW)
  adminNote         String?
  fileUrl           String?
  configJson        Json?
  imageData         Json?
  myThemeId         String?
  pendingFileUrl    String?
  pendingConfigJson Json?
  pendingImageData  Json?
  pendingMyThemeId  String?
  pendingAdminNote  String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  theme             Theme             @relation(fields: [themeId], references: [id], onDelete: Cascade)
}

model Purchase {
  id              String         @id @default(uuid())
  buyerId         String
  themeId         String
  amount          Int
  pgTransactionId String?        @unique
  status          PurchaseStatus @default(PENDING)
  createdAt       DateTime       @default(now())
  refundReason    String?
  refundedAt      DateTime?
  versionId       String?
  isDownloaded    Boolean        @default(false)
  buyer           User           @relation("UserPurchases", fields: [buyerId], references: [id])
  theme           Theme          @relation(fields: [themeId], references: [id])
  version         ThemeVersion?  @relation(fields: [versionId], references: [id])
}

model Inquiry {
  id        String         @id @default(uuid())
  userId    String
  category  String         @default("기타")
  title     String
  content   String
  images    String[]       @default([])
  status    InquiryStatus  @default(OPEN)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation("UserInquiries", fields: [userId], references: [id])
  replies   InquiryReply[]
}

model InquiryReply {
  id        String   @id @default(uuid())
  inquiryId String
  authorId  String
  content   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  author    User     @relation("UserInquiryReplies", fields: [authorId], references: [id])
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
}

model Report {
  id         String       @id @default(uuid())
  reporterId String
  themeId    String
  reason     String
  detail     String?
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  reporter   User         @relation("UserReports", fields: [reporterId], references: [id])
  theme      Theme        @relation("ThemeReports", fields: [themeId], references: [id])
}

model ThemeLike {
  id        String   @id @default(uuid())
  userId    String
  themeId   String
  createdAt DateTime @default(now())
  theme     Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, themeId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  themeId   String
  rating    Int
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  images    String[] @default([])
  rewarded  Boolean  @default(false)
  theme     Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, themeId])
}

model MyThemeFolder {
  id        String    @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime  @default(now())
  sortOrder Int?      @default(0)
  themes    MyTheme[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MyTheme {
  id              String         @id @default(uuid())
  userId          String
  folderId        String?
  name            String
  os              String
  previewImageUrl String?
  trashed         Boolean        @default(false)
  trashedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  configJson      Json?
  imageData       Json?
  themePackageId  String?        @unique
  folder          MyThemeFolder? @relation(fields: [folderId], references: [id])
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Mailbox {
  id        String        @id @default(uuid())
  userId    String
  type      MailboxType
  title     String
  content   String
  images    String[]      @default([])
  status    MailboxStatus @default(PENDING)
  adminNote String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GalleryPost {
  id          String            @id @default(uuid())
  userId      String
  themeName   String
  description String?
  images      String[]          @default([])
  storeLink   String?
  themeId     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  comments    GalleryComment[]
  likes       GalleryLike[]
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions   GalleryReaction[]
}

model GalleryLike {
  id        String      @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime    @default(now())
  post      GalleryPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model GalleryReaction {
  id        String      @id @default(uuid())
  userId    String
  postId    String
  emoji     String
  createdAt DateTime    @default(now())
  post      GalleryPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, emoji])
}

model GalleryComment {
  id        String                 @id @default(uuid())
  postId    String
  userId    String
  content   String
  isDeleted Boolean                @default(false)
  createdAt DateTime               @default(now())
  parentId  String?
  parent    GalleryComment?        @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   GalleryComment[]       @relation("CommentReplies")
  post      GalleryPost            @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports   GalleryCommentReport[]
}

model GalleryCommentReport {
  id         String         @id @default(uuid())
  commentId  String
  reporterId String
  isHandled  Boolean        @default(false)
  createdAt  DateTime       @default(now())
  comment    GalleryComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporter   User           @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([commentId, reporterId])
}

model Subscription {
  id            String                @id @default(uuid())
  userId        String                @unique
  status        SubscriptionStatus    @default(ACTIVE)
  amount        Int                   @default(4900)
  billingKey    String?
  startedAt     DateTime              @default(now())
  nextBillingAt DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  customerKey   String?
  cardCompany   String?
  cardNumber    String?
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments      SubscriptionPayment[]
}

model SubscriptionPayment {
  id              String                    @id @default(uuid())
  subscriptionId  String
  userId          String
  amount          Int
  status          SubscriptionPaymentStatus @default(COMPLETED)
  pgTransactionId String?                   @unique
  periodStart     DateTime                  @db.Timestamptz(6)
  periodEnd       DateTime                  @db.Timestamptz(6)
  paidAt          DateTime                  @default(now()) @db.Timestamptz(6)
  createdAt       DateTime                  @default(now()) @db.Timestamptz(6)
  subscription    Subscription              @relation(fields: [subscriptionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum Role {
  USER
  CREATOR
  ADMIN
}

enum ThemeStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum BuildStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum ThemeOptionStatus {
  ACTIVE
  PENDING_UPDATE
  PENDING_NEW
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
  REFUND_REQUESTED
}

enum InquiryStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum MailboxType {
  SUGGESTION
  BUG_REPORT
}

enum MailboxStatus {
  PENDING
  REVIEWED
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum SubscriptionPaymentStatus {
  COMPLETED
  FAILED
  REFUNDED
}

enum PointType {
  REFERRAL_REWARD
  PURCHASE_USE
  ADMIN_GRANT
  REFUND
  EXPIRY
  REVIEW_REWARD
}

enum NotificationType {
  FOLLOW
  NEW_THEME
  CREDIT_EXPIRY
  PURCHASE_COMPLETE
  REFUND_COMPLETE
  THEME_APPROVED
  THEME_REJECTED
  SYSTEM
}
